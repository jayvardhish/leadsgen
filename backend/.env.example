# MongoDB Atlas URI (get from https://cloud.mongodb.com)
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/smartlead?retryWrites=true&w=majority

# Server port (Render sets this automatically)
PORT=5000

# DeepSeek API Key (get from https://platform.deepseek.com/api_keys)
# Leave blank to use built-in fallback (no cost)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
